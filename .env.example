# Copy to .env and replace all passwords before exposing the stack.
POSTGRES_PASSWORD=replace-this-database-password
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-this-grafana-password
PING_INTERVAL_SECONDS=5
REQUEST_TIMEOUT_SECONDS=10
STATUS_REFRESH_SECONDS=5
PINGER_PORT=8080
GRAFANA_PORT=3000
